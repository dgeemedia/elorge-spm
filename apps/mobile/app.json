{
  "expo": {
    "name": "Elorge SPM",
    "slug": "elorge-spm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1A3C6E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elorge.spm"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C6E"
      },
      "package": "com.elorge.spm"
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A3C6E"
        }
      ]
    ]
  }
}
